<%- include("partials/materio-head", { title }) %>
  <% const safeSearchQuery = typeof searchQuery !== "undefined" ? searchQuery : ""; %>
  <body>
    <div class="layout-wrapper layout-content-navbar">
      <div class="layout-container">
        <%- include("partials/materio-sidebar", { activePage }) %>

        <div class="layout-page">
          <%- include("partials/materio-navbar", { title, searchQuery: safeSearchQuery }) %>

          <div class="content-wrapper">
            <div class="container-xxl flex-grow-1 container-p-y">
              <% if (message) { %>
              <div class="alert alert-success alert-dismissible" role="alert">
                <%= message %>
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
              </div>
              <% } %>

              <% if (error) { %>
              <div class="alert alert-danger alert-dismissible" role="alert">
                <%= error %>
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
              </div>
              <% } %>

              <div class="card">
                <div class="card-header d-flex justify-content-between align-items-center">
                  <div>
                    <h5 class="mb-0">Danh sach san pham</h5>
                    <% if (safeSearchQuery) { %>
                    <small class="text-muted">Ket qua tim kiem cho: "<%= safeSearchQuery %>"</small>
                    <% } %>
                  </div>
                  <a href="/trees/new" class="btn btn-primary">
                    <i class="ri-add-line me-1"></i>
                    Them san pham
                  </a>
                </div>
                <form action="/trees/delete-selected" method="POST" id="bulkDeleteForm"></form>
                <div class="card-body border-top">
                  <div class="dropdown">
                    <button
                      class="btn btn-outline-primary dropdown-toggle"
                      type="button"
                      data-bs-toggle="dropdown"
                      aria-expanded="false">
                      Tac vu nhanh
                    </button>
                    <ul class="dropdown-menu dropdown-menu-end">
                      <li>
                        <button
                          type="submit"
                          form="bulkDeleteForm"
                          id="bulkDeleteAction"
                          class="dropdown-item text-danger"
                          disabled>
                          <i class="ri-delete-bin-6-line me-2"></i>
                          Xoa muc da chon
                        </button>
                      </li>
                    </ul>
                  </div>
                </div>
                <div class="table-responsive text-nowrap">
                  <table class="table">
                    <thead>
                      <tr>
                        <th style="width: 48px" class="text-center">
                          <input type="checkbox" id="selectAllTrees" class="form-check-input" />
                        </th>
                        <th style="width: 72px">ID</th>
                        <th>Ten san pham</th>
                        <th>Hinh anh</th>
                        <th>Mo ta</th>
                        <th class="text-center">Hanh dong</th>
                      </tr>
                    </thead>
                    <tbody class="table-border-bottom-0">
                      <% if (!trees.length) { %>
                      <tr>
                        <td colspan="6" class="text-center py-6 text-muted">
                          <%= safeSearchQuery ? "Khong tim thay san pham phu hop." : "Chua co du lieu san pham." %>
                        </td>
                      </tr>
                      <% } %>
                      <% trees.forEach((tree, index) => { %>
                      <tr>
                        <td class="text-center">
                          <input
                            type="checkbox"
                            class="form-check-input tree-checkbox"
                            name="selectedTreeIds"
                            value="<%= tree._id %>"
                            form="bulkDeleteForm" />
                        </td>
                        <td><span class="fw-semibold">#<%= index + 1 %></span></td>
                        <td>
                          <span class="fw-medium"><%= tree.treename %></span>
                        </td>
                        <td>
                          <img
                            src="<%= tree.image %>"
                            alt="<%= tree.treename %>"
                            class="rounded"
                            width="64"
                            height="64"
                            onerror="this.src='<%= imageOptions[1] %>'" />
                        </td>
                        <td style="max-width: 420px; white-space: normal"><%= tree.description %></td>
                        <td class="text-center">
                          <a href="/trees/<%= tree._id %>/edit" class="btn btn-sm btn-outline-primary me-2">
                            <i class="ri-edit-box-line me-1"></i>Sua
                          </a>
                          <form
                            action="/trees/<%= tree._id %>/delete"
                            method="POST"
                            class="d-inline"
                            onsubmit="return confirm('Ban co chac chan muon xoa san pham nay?');">
                            <button type="submit" class="btn btn-sm btn-outline-danger">
                              <i class="ri-delete-bin-6-line me-1"></i>Xoa
                            </button>
                          </form>
                        </td>
                      </tr>
                      <% }) %>
                    </tbody>
                  </table>
                </div>
              </div>

              <% if (trees.length) { %>
              <div class="card mt-4">
                <div class="card-body d-flex justify-content-between align-items-center">
                  <div>
                    <h6 class="mb-1">Reset danh sach</h6>
                    <p class="mb-0 text-muted">Xoa toan bo du lieu san pham trong danh sach.</p>
                  </div>
                  <form id="resetAllForm" action="/trees/reset" method="POST">
                    <button type="submit" class="btn btn-danger">
                      <i class="ri-delete-bin-line me-1"></i>
                      Reset danh sach
                    </button>
                  </form>
                </div>
              </div>
              <% } %>
            </div>
            <%- include("partials/materio-footer") %>
            <div class="content-backdrop fade"></div>
          </div>
        </div>
      </div>
      <div class="layout-overlay layout-menu-toggle"></div>
    </div>
    <script>
      const selectAllTrees = document.getElementById("selectAllTrees");
      const treeCheckboxes = Array.from(document.querySelectorAll(".tree-checkbox"));
      const bulkDeleteAction = document.getElementById("bulkDeleteAction");

      const refreshBulkDeleteState = () => {
        const selectedCount = treeCheckboxes.filter((checkbox) => checkbox.checked).length;
        if (bulkDeleteAction) {
          bulkDeleteAction.disabled = selectedCount === 0;
        }

        if (!selectAllTrees) return;
        if (!treeCheckboxes.length) {
          selectAllTrees.checked = false;
          selectAllTrees.indeterminate = false;
          return;
        }

        selectAllTrees.checked = selectedCount === treeCheckboxes.length;
        selectAllTrees.indeterminate = selectedCount > 0 && selectedCount < treeCheckboxes.length;
      };

      if (selectAllTrees) {
        selectAllTrees.addEventListener("change", () => {
          treeCheckboxes.forEach((checkbox) => {
            checkbox.checked = selectAllTrees.checked;
          });
          refreshBulkDeleteState();
        });
      }

      treeCheckboxes.forEach((checkbox) => {
        checkbox.addEventListener("change", refreshBulkDeleteState);
      });

      const bulkDeleteForm = document.getElementById("bulkDeleteForm");
      if (bulkDeleteForm) {
        bulkDeleteForm.addEventListener("submit", (event) => {
          if (bulkDeleteAction && bulkDeleteAction.disabled) {
            event.preventDefault();
            return;
          }

          const confirmed = confirm("Ban co chac chan muon xoa cac san pham da chon?");
          if (!confirmed) {
            event.preventDefault();
          }
        });
      }

      const resetAllForm = document.getElementById("resetAllForm");
      if (resetAllForm) {
        resetAllForm.addEventListener("submit", (event) => {
          const confirmed = confirm("Xoa tat ca san pham?");
          if (!confirmed) {
            event.preventDefault();
          }
        });
      }

      refreshBulkDeleteState();
    </script>
<%- include("partials/materio-scripts") %>
