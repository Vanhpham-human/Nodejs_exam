<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= title %></title>
    <link rel="stylesheet" href="/style.css" />
  </head>
  <body>
    <header class="site-header">
      <div class="container header-inner">
        <a href="/" class="brand">Tree Shop</a>
        <nav>
          <a href="/about">About me</a>
        </nav>
      </div>
    </header>

    <main class="container">
      <h1>Tree Shop</h1>

      <% if (error) { %>
      <p class="alert error"><%= error %></p>
      <% } %>

      <section class="form-section">
        <div class="left-preview">
          <img
            src="https://i.pinimg.com/736x/ad/cd/e6/adcde6874d662115cd68f945662c4aba.jpg"
            alt="Tree preview"
            onerror="this.src='<%= imageOptions[0] %>'"
          />
        </div>
        <div class="right-form">
          <form method="POST" action="/trees/add" class="tree-form">
            <label for="treename">Tree Name</label>
            <input
              id="treename"
              name="treename"
              value="<%= formData.treename %>"
              placeholder="Phonng lan"
              required
            />

            <label for="description">Description</label>
            <textarea
              id="description"
              name="description"
              rows="4"
              placeholder="Description..."
              required
            ><%= formData.description %></textarea>

            <label for="image">Image</label>
            <div class="image-row">
              <input
                id="image"
                name="image"
                value="<%= formData.image || imageOptions[0] %>"
                list="image-list"
                placeholder="/provided-images/your-image.png"
              />
              <button type="button" class="btn secondary" id="browseBtn">
                Browser
              </button>
            </div>
            <datalist id="image-list">
              <% imageOptions.forEach((img) => { %>
              <option value="<%= img %>"></option>
              <% }) %>
            </datalist>

            <div class="actions">
              <button type="submit" class="btn add">Add</button>
            </div>
          </form>

          <form method="POST" action="/trees/reset" class="reset-form">
            <button type="submit" class="btn reset">Reset</button>
          </form>
        </div>
      </section>

      <section class="list-section">
        <table>
          <thead>
            <tr>
              <th>Id</th>
              <th>Name</th>
              <th>Image</th>
              <th>Description</th>
            </tr>
          </thead>
          <tbody>
            <% if (!trees.length) { %>
            <tr>
              <td colspan="4" class="empty">No tree data yet.</td>
            </tr>
            <% } %>
            <% trees.forEach((tree, index) => { %>
            <tr>
              <td><%= index + 1 %></td>
              <td><%= tree.treename %></td>
              <td>
                <img
                  class="thumb"
                  src="<%= tree.image %>"
                  alt="<%= tree.treename %>"
                  onerror="this.src='<%= imageOptions[1] %>'"
                />
              </td>
              <td><%= tree.description %></td>
            </tr>
            <% }) %>
          </tbody>
        </table>
      </section>
    </main>

    <footer class="site-footer">
      <div class="container footer-inner caption-footer">
        <p>So 8, Ton That Thuyet, Cau Giay, Ha Noi</p>
      </div>
    </footer>

    <script>
      const imgInput = document.getElementById("image");
      const browseBtn = document.getElementById("browseBtn");
      // const imageOptions = <%- JSON.stringify(imageOptions) %>;
      let imageIndex = 0;

      browseBtn.addEventListener("click", () => {
        imageIndex = (imageIndex + 1) % imageOptions.length;
        imgInput.value = imageOptions[imageIndex];
      });
    </script>
  </body>
</html>
